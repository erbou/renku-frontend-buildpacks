#!/usr/bin/env bash

unalias -a
set -euCo pipefail

echo -e "=== 🔧 \033[1mRenku Coding Agent buildpack\033[0m ==="

AI_LAYER="${CNB_LAYERS_DIR}/agent"
mkdir -p "${AI_LAYER}"

AI_LAYER_CACHE="${CNB_LAYERS_DIR}/cache"
mkdir -p "${AI_LAYER_CACHE}/.npm"

# Use npm cache directory inside this layer
export NPM_CONFIG_CACHE="${AI_LAYER_CACHE}/.npm"

log()  { echo "-----> $*"; }
info() { echo "       $*"; }

# Metadata
cat > "${AI_LAYER}.toml" <<EOL
[types]
build = true
cache = false
launch = true

[metadata]
description = "Agentic runtime"
EOL

# Metadata
cat > "${AI_LAYER_CACHE}.toml" <<EOL
[types]
build  = true
cache = true
launch = false

[metadata]
description = "Agentic cache"
EOL

# Launch environment
ENV_LAUNCH="${AI_LAYER}/env.launch"

mkdir -p "${ENV_LAUNCH}"
printf '%s' "${AI_LAYER}/bin" > "${ENV_LAUNCH}/PATH.prepend"
printf ':' > "${ENV_LAUNCH}/PATH.delim"

# Build environment
ENV_BUILD="${AI_LAYER}/env.build"
mkdir -p "${ENV_BUILD}"

printf '%s' "${AI_LAYER}/bin" > "${ENV_BUILD}/PATH.prepend"
printf ':' > "${ENV_BUILD}/PATH.delim"

# Selective npm installation
if [[ -z "${BP_RENKU_AI_AGENTS:-}" && -f "project.toml" ]]; then
  BP_RENKU_AI_AGENTS=$(awk 'BEGIN { is_set = 0; has_value=0 }
    /^\[\[io\.buildpacks\.build\.env\]\]/ {
        is_set=0
        has_value=0
    }
    /^[[:space:]]*name[[:space:]]*=[[:space:]]*"BP_RENKU_AI_AGENTS"[[:space:]]*$/ {
        is_set=1
    }
    /^[[:space:]]*value[[:space:]]*=/ {
        match($0, /"([^"]*)"/)
        value=substr($0, RSTART+1, RLENGTH-2)
        has_value=1
    }
    is_set==1 && has_value==1 {
        print value
        exit
    }' project.toml)
fi

info "Install ${BP_RENKU_AI_AGENTS:-}"

mkdir -p "${AI_LAYER}/agentic/"
mkdir -p "${AI_LAYER}/bin/"
mkdir -p "${AI_LAYER_CACHE}/agentic"

cp "${CNB_BUILDPACK_DIR}/bin/harness-sbx" "${AI_LAYER}/bin/harness-sbx"
chmod a+x "${AI_LAYER}/bin/harness-sbx"
echo "#!/bin/bash" >> "${AI_LAYER}/bin/sbx"
chmod a+rx "${AI_LAYER}/bin/sbx"

for agent in ${BP_RENKU_AI_AGENTS:-}; do
	name=${agent%@*}
	version=${agent##*@}

	if [[ "${version}" == "${name}" ]]; then
		version=$(sed -En \
			'/^\[metadata\]/,/^$/s/^[[:space:]]*'"${name}"'_version[[:space:]]=[[:space:]]"([~^]?[0-9.]+)"[[:space:]]*$/\1/p' \
			"${CNB_BUILDPACK_DIR}/buildpack.toml" 2>/dev/null || echo "")
	fi

	[[ "${version}" =~ ^([~^]?[0-9]+(\.[0-9]+){0,2})?$ ]] || continue

	case "${name}" in
	pi)
		log "Install PI agent [${version:-latest}]"
		npm install --prefix "${AI_LAYER}" -g "@earendil-works/pi-coding-agent${version:+@$version}"
		if [[ -d "./.${name}" ]]; then
			cp -RpP "./.${name}" "${AI_LAYER_CACHE}/agentic/${name}"
			node -e 'try {
				const fs = require("fs");
				const cfg = JSON.parse(fs.readFileSync(process.argv[1], "utf8"));
				console.log((cfg.packages || []).join(" "));
			} catch(e) {
				console.log("");
			}' "./.${name}/settings.json"|while read -r pkg; do
				[[ -n "${pkg:-}" ]] && PI_CODING_AGENT_DIR="${AI_LAYER_CACHE}/agentic/${name}" "${AI_LAYER}/bin/pi" install "${pkg}"
			done
			tar -C "${AI_LAYER_CACHE}/agentic/${name}" -czf "${AI_LAYER}/agentic/${name}.tgz" .
		fi

		printf '/home/renku/work/.pi/agent' >  "${ENV_LAUNCH}/PI_CODING_AGENT_DIR.override"
		printf '1' >  "${ENV_LAUNCH}/PI_SKIP_VERSION_CHECK.override"
		mkdir -p "${AI_LAYER}/exec.d/"
		cat > "${AI_LAYER}/exec.d/init-pi.sh" <<- EOL
			#!/usr/bin/env bash
			if [[ -z "\${PI_CODING_AGENT_DIR:-}" ]]; then
			  exit 0
			elif ! mkdir -p "\${PI_CODING_AGENT_DIR}" 2>/dev/null; then
			  echo "${name} disabled: cannot create dir \${PI_CODING_AGENT_DIR}" >&2
			  exit 0
			fi
			if [[ -f "${AI_LAYER}/agentic/${name}.tgz" ]]; then
			  tar -C "\${PI_CODING_AGENT_DIR}" -xzf "${AI_LAYER}/agentic/${name}.tgz"
			fi
		EOL
		chmod a+rx "${AI_LAYER}/exec.d/init-pi.sh"
		printf '#!/bin/bash\n%s/bin/harness-sbx --pi\n' "${AI_LAYER}" > "${AI_LAYER}/bin/pi-sbx"
		chmod a+rx "${AI_LAYER}/bin/pi-sbx"
		echo "${AI_LAYER}/bin/harness-sbx --start --pi &" >> "${AI_LAYER}/bin/sbx"
		;;
	claude)
		log "Install Claude agent [${version:-latest}]"
		npm install --prefix "${AI_LAYER}" -g "@anthropic-ai/claude-code${version:+@$version}"
		if [[ -d "./.${name}" ]]; then
			cp -RpP "./.${name}" "${AI_LAYER_CACHE}/agentic/${name}"
			tar -C "${AI_LAYER_CACHE}/agentic/${name}" -czf "${AI_LAYER}/agentic/${name}.tgz" .
		fi
		printf '/home/renku/work/.claude' >    "${ENV_LAUNCH}/CLAUDE_CONFIG_DIR.override"
		mkdir -p "${AI_LAYER}/exec.d/"
		cat > "${AI_LAYER}/exec.d/init-claude.sh" <<- EOL
			#!/usr/bin/env bash
			if [[ -z "\${CLAUDE_CONFIG_DIR:-}" ]]; then
			  exit 0
			elif ! mkdir -p "\${CLAUDE_CONFIG_DIR}" 2>/dev/null; then
			  echo "${name} disabled: cannot create dir \${CLAUDE_CONFIG_DIR}" >&2
			  exit 0
			fi
			if [[ -f "${AI_LAYER}/agentic/${name}.tgz" ]]; then
			  tar -C "\${CLAUDE_CONFIG_DIR}" -xzf "${AI_LAYER}/agentic/${name}.tgz"
			fi
		EOL
		chmod a+rx "${AI_LAYER}/exec.d/init-claude.sh"
		printf '#!/bin/bash\n%s/bin/harness-sbx --claude\n' "${AI_LAYER}" > "${AI_LAYER}/bin/claude-sbx"
		chmod a+rx "${AI_LAYER}/bin/claude-sbx"
		echo "${AI_LAYER}/bin/harness-sbx --start --claude &" >> "${AI_LAYER}/bin/sbx"
		;;
	codex)
		log "Install Codex agent [${version:-latest}]"
		npm install --prefix "${AI_LAYER}" -g "@openai/codex${version:+@$version}"
		if [[ -d "./.${name}" ]]; then
			cp -RpP "./.${name}" "${AI_LAYER_CACHE}/agentic/${name}"
			tar -C "${AI_LAYER_CACHE}/agentic/${name}" -czf "${AI_LAYER}/agentic/${name}.tgz" .
		fi
		printf '/home/renku/work/.codex' >     "${ENV_LAUNCH}/CODEX_HOME.override"
		mkdir -p "${AI_LAYER}/exec.d/"
		cat > "${AI_LAYER}/exec.d/init-codex.sh" <<- EOL
			#!/usr/bin/env bash
			if [[ -z "\${CODEX_HOME:-}" ]]; then
			  exit 0
			elif ! mkdir -p "\${CODEX_HOME}" 2>/dev/null; then
			  echo "${name} disabled: cannot create dir \${CODEX_HOME}" >&2
			  exit 0
			fi
			if [[ -f "${AI_LAYER}/agentic/${name}.tgz" ]]; then
			  tar -C "\${CODEX_HOME}" -xzf "${AI_LAYER}/agentic/${name}.tgz"
			fi
		EOL
		chmod a+rx "${AI_LAYER}/exec.d/init-codex.sh"
		printf '#!/bin/bash\n%s/bin/harness-sbx --codex\n' "${AI_LAYER}" > "${AI_LAYER}/bin/codex-sbx"
		chmod a+rx "${AI_LAYER}/bin/codex-sbx"
		echo "${AI_LAYER}/bin/harness-sbx --start --codex &" >> "${AI_LAYER}/bin/sbx"
		;;
	esac
done
echo "wait" >> "${AI_LAYER}/bin/sbx"

# SET SANDBOX START COMMAND
cat >"${CNB_LAYERS_DIR}/launch.toml" <<EOL
[[processes]]
type = "harness-sbx"
command = ["tini", "-g", "--"]
args = ["bash", "${AI_LAYER}/bin/sbx"]
default = false
EOL

# Cleanup
log "Cleanup"
rm -rf "${AI_LAYER}/.cache"
rm -rf "${AI_LAYER_CACHE}/.npm/_logs"

info "Coding Agent installed"
